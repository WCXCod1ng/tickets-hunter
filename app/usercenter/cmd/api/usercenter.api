syntax = "v1"

info (
	title:   "用户中心服务"
	desc:    "包含注册、登录、用户信息获取"
	author:  "fleabane"
	version: "v1"
)

type (
	// 注册请求
	RegisterReq {
		Mobile   string `json:"mobile,optional" validate:"required"`
		Password string `json:"password,optional" validate:"required,min=6"`
		Nickname string `json:"nickname,optional" validate:"required,min=5,max=20"`
		Sex      int64  `json:"sex,optional" default:"0" validate:"oneof=0 1 2"` // 0未知 1男 2女
		Avatar   string `json:"avatar,optional" validate:"omitempty,url"`
		Info     string `json:"info,optional" validate:"omitempty,max=255"`
	}
	// 注册/登录响应
	LoginRegisterResp {
		Token        string `json:"token,optional"`
		TokenExpire  int64  `json:"token_expire,optional"`
		RefreshToken string `json:"refresh_token,optional"`
	}
	// 登录请求
	LoginReq {
		Mobile   string `json:"mobile,optional"`
		Password string `json:"password,optional"`
	}
	// 刷新 Token 的请求与响应
	RefreshReq {
		RefreshToken string `json:"refresh_token,optional"`
	}
	RefreshResp {
		AccessToken  string `json:"access_token,optional"`
		AccessExpire int64  `json:"access_expire,optional"`
		RefreshToken string `json:"refresh_token,optional"`
		RefreshAfter int64  `json:"refresh_after,optional"`
	}
	// 用户登出请求
	LogoutReq {
		RefreshToken string `json:"refresh_token,optional" validate:"required,min=1"`
	}
	// 用户信息响应
	UserDetailResp {
		Id       int64  `json:"id,optional"`
		Mobile   string `json:"mobile,optional"`
		Nickname string `json:"nickname,optional"`
		Sex      int64  `json:"sex,optional"`
		Avatar   string `json:"avatar,optional"`
		Info     string `json:"info,optional"`
	}
)

// 不需要登录验证的接口
@server (
	prefix: usercenter/v1
	group:  user
)
service usercenter-api {
	@doc "用户注册"
	@handler register
	post /register (RegisterReq) returns (LoginRegisterResp)

	@doc "用户登录"
	@handler login
	post /login (LoginReq) returns (LoginRegisterResp)

	@doc "token刷新"
	@handler refresh
	post /refresh (RefreshReq) returns (RefreshResp)
}

// 需要登录验证的接口
@server (
	prefix: usercenter/v1
	group:  user
	jwt:    Auth // 开启JWT认证，配置中需对应 Auth.AccessSecret
)
service usercenter-api {
	@doc "获取用户信息"
	@handler detail
	post /detail returns (UserDetailResp)

	@doc "用户登出"
	@handler logout
	post /logout (LogoutReq)
}

