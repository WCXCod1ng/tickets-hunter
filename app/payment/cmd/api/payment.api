syntax = "v1"

// 请求参数
type PayReq {
	OrderSn string `json:"order_sn"` // 只需要传订单号，金额和座位让后端自己查防篡改
}

// 响应参数
type PayResp {
	Success bool   `json:"success"`
	Message string `json:"message"`
}

// 需登录鉴权的路由组
@server (
	jwt:    Auth // 开启 JWT 鉴权
	prefix: /payment/v1
)
service order-api {
	@doc "发起订单支付 (Saga 分布式事务)"
	@handler Pay
	post /pay (PayReq) returns (PayResp)
}

